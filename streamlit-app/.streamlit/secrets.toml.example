# Copy this file and name it secrets.toml (do NOT commit secrets.toml to GitHub)
# On Streamlit Cloud, add these under Settings → Secrets

DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# Email settings (optional — requests save without email if not set)
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "your-email@gmail.com"
SMTP_PASS = "your-app-password"
